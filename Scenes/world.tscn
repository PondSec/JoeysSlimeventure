[sub_resource type="GDScript" id="GDScript_a02cp"]
script/source = "extends Node2D

var player_scene = preload(\"res://Scenes/player.tscn\")
@onready var pause_menu = $PauseMenu

func _ready():
	# Nur ausführen wenn wir ein Client sind (nicht auf Server)
	if not multiplayer.is_server():
		# Spawn zunächst nur sich selbst
		spawn_player(multiplayer.get_unique_id())
		
		if multiplayer.multiplayer_peer.get_connection_status() == MultiplayerPeer.CONNECTION_CONNECTED:
			# Frage alle Spieler vom Server an
			request_all_players.rpc_id(1)  # An Server (ID 1) senden

	multiplayer.peer_connected.connect(_on_peer_connected)
	multiplayer.peer_disconnected.connect(_on_peer_disconnected)

# Auf dem Server
@rpc(\"any_peer\", \"reliable\")
func request_all_players():
	if multiplayer.is_server():
		var sender_id = multiplayer.get_remote_sender_id()
		print(\"📋 Client \", sender_id, \" fordert alle Spielerdaten an\")
		
		# Sende alle verbundenen Spieler an den neuen Client
		for peer_id in multiplayer.get_peers():
			if peer_id != sender_id:  # Nicht sich selbst senden
				spawn_player_for_client.rpc_id(sender_id, peer_id)

@rpc(\"authority\", \"reliable\")
func spawn_player_for_client(peer_id):
	# Spawn einen Spieler für einen anderen Client
	if not has_node(str(peer_id)):
		var player = player_scene.instantiate()
		player.name = str(peer_id)
		player.set_multiplayer_authority(peer_id)
		add_child(player)
		
		# Setze Position (kann vom Server kommen)
		var spawn_points = get_tree().get_nodes_in_group(\"spawn_points\")
		if spawn_points.size() > 0:
			player.global_position = spawn_points[randi() % spawn_points.size()].global_position
		else:
			player.global_position = Vector2(randf_range(100, 900), randf_range(100, 500))

@rpc(\"any_peer\", \"reliable\")
func request_players():
	# Wird auf dem Server ausgeführt
	if multiplayer.is_server():
		var sender_id = multiplayer.get_remote_sender_id()
		print(\"📋 Client \", sender_id, \" fordert Spielerdaten an\")
		send_player_data.rpc_id(sender_id)

@rpc(\"authority\", \"reliable\")
func send_player_data():
	# Wird auf Clients ausgeführt - empfängt Spielerdaten vom Server
	print(\"📨 Empfange Spielerdaten vom Server\")
	# Hier Spieler basierend auf Server-Daten spawnen

func _on_peer_connected(peer_id):
	print(\"🔗 Neuer Spieler verbunden: \", peer_id)
	if not multiplayer.is_server():
		spawn_player(peer_id)

func _on_peer_disconnected(peer_id):
	print(\"❌ Spieler getrennt: \", peer_id)
	if has_node(str(peer_id)):
		get_node(str(peer_id)).queue_free()

func spawn_player(peer_id):
	if get_node_or_null(str(peer_id)):
		return  # Spieler existiert bereits
	
	var player = player_scene.instantiate()
	player.name = str(peer_id)
	player.set_multiplayer_authority(peer_id)
	add_child(player)
	
	# Zufällige Spawn-Position
	var spawn_points = get_tree().get_nodes_in_group(\"spawn_points\")
	if spawn_points.size() > 0:
		player.global_position = spawn_points[randi() % spawn_points.size()].global_position
	else:
		player.global_position = Vector2(randf_range(100, 900), randf_range(100, 500))
	
	# Synchronisiere den neuen Spieler mit allen Clients
	if multiplayer.is_server():
		sync_player_spawn.rpc(peer_id, player.global_position)

@rpc(\"authority\", \"reliable\")
func sync_player_spawn(peer_id, position):
	# Client-seitig: Spiele den Spieler, falls nicht vorhanden
	if not has_node(str(peer_id)) and peer_id != multiplayer.get_unique_id():
		var player = player_scene.instantiate()
		player.name = str(peer_id)
		player.set_multiplayer_authority(peer_id)
		add_child(player)
		player.global_position = position

func _input(event):
	# Pausensteuerung
	if event.is_action_pressed(\"Pause\"):  # Standardmäßig ESC
		pause_menu.toggle_pause()
	if event.is_action_pressed(\"UI\"):
		$PlayerModel/CanvasLayer.visible = !$PlayerModel/CanvasLayer.visible
"

