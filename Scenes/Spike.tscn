[sub_resource type="GDScript" id="GDScript_agh12"]
script/source = "extends Sprite2D

@onready var area: Area2D = $Area2D
var tween: Tween
var player_took_damage: bool = false
var damage_timer: float = 0.0
const DAMAGE_VISIBILITY_TIME: float = 1.0  # Wie lange die Spikes nach Schaden sichtbar bleiben
var is_player_glowing: bool = false
var can_deal_damage: bool = true
var damage_cooldown: float = 0.0
const DAMAGE_COOLDOWN_TIME: float = 0.5  # Cooldown zwischen Schadensereignissen
var has_dealt_damage: bool = false  # Ob diese Spikes schon einmal Schaden gemacht haben

func _ready():
	add_to_group(\"spikes\")
	# Initialisiere die Transparenz - komplett unsichtbar am Anfang
	modulate.a = 0.0  # Komplett unsichtbar

func _physics_process(delta: float) -> void:
	# Timer für die Schadenssichtbarkeit aktualisieren
	if player_took_damage:
		damage_timer -= delta
		if damage_timer <= 0:
			player_took_damage = false
			update_visibility_based_on_state()
	
	# Cooldown-Timer aktualisieren
	if !can_deal_damage:
		damage_cooldown -= delta
		if damage_cooldown <= 0:
			can_deal_damage = true
	
	# Schaden nur verursachen, wenn Cooldown abgelaufen ist
	if can_deal_damage:
		for body in area.get_overlapping_bodies():
			if body.is_in_group(\"players\") or body.is_in_group(\"enemies\"):
				print(\"Autsch! Spieler erwischt.\")
				# Schadensquelle = Position der Spikes
				body.take_damage(12, global_position)
				# Spikes nach Schaden sichtbar machen
				make_spikes_visible_on_damage()
				# Markieren, dass diese Spikes Schaden gemacht haben
				has_dealt_damage = true
				# Cooldown aktivieren
				can_deal_damage = false
				damage_cooldown = DAMAGE_COOLDOWN_TIME
				break  # Nur einem Spieler pro Frame Schaden zufügen

func _on_player_glow_changed(is_glowing: bool):
	is_player_glowing = is_glowing
	update_visibility_based_on_state()

func make_spikes_visible_on_damage():
	player_took_damage = true
	damage_timer = DAMAGE_VISIBILITY_TIME
	
	# Erstelle einen neuen Tween für den Übergang
	if tween:
		tween.kill()
	
	tween = create_tween()
	tween.set_ease(Tween.EASE_IN_OUT)
	tween.set_trans(Tween.TRANS_SINE)
	
	# Sofort auf maximale Sichtbarkeit setzen
	tween.tween_property(self, \"modulate:a\", 1.0, 0.2)

func update_visibility_based_on_state():
	# Bestimme den Ziel-Alpha-Wert
	var target_alpha: float
	
	if player_took_damage:
		# Wenn Schaden aktiv ist, immer volle Sichtbarkeit
		target_alpha = 1.0
	else:
		if is_player_glowing:
			# Beim Leuchten immer volle Sichtbarkeit
			target_alpha = 1.0
		else:
			# Wenn nicht geleuchtet wird: 0.3 wenn Schaden gemacht wurde, sonst 0.0
			target_alpha = 0.3 if has_dealt_damage else 0.0
	
	# Erstelle einen neuen Tween für den Übergang
	if tween:
		tween.kill()
	
	tween = create_tween()
	tween.set_ease(Tween.EASE_IN_OUT)
	tween.set_trans(Tween.TRANS_SINE)
	
	# Sanfter Übergang über 0.5 Sekunden
	tween.tween_property(self, \"modulate:a\", target_alpha, 0.5)
"

