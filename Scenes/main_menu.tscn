resource_name = "menu"
script/source = "extends Control

const CONFIG_PATH = \"user://settings.cfg\"
const PLAYER_ID_PATH = \"user://player_id.save\"
const SECRET_SALT = \"X7!d9$#_MySaltHere_2025\"

var config := ConfigFile.new()
var game_messages_container: VBoxContainer
var message_timer: Timer

# Toast-Management
const MAX_CONCURRENT_TOASTS = 5
var active_toasts: Array = []
var toast_pool: Array = []
var toast_stats = {
	\"shown\": 0,
	\"clicked\": 0,
	\"dismissed\": 0
}
var toast_settings = {
	\"enabled\": true,
	\"duration_multiplier\": 1.0,
	\"max_count\": 5,
	\"position\": \"bottom_right\"
}

@onready var ip_input: LineEdit = $MultiPlayer/VBoxContainer/IPInput
@onready var port_input: LineEdit = $MultiPlayer/VBoxContainer/PortInput
@onready var pact_notes: Label = $PatchNotes
@onready var volume_slider: HSlider = $SettingsPanel/VBoxContainer/VolumeSlider

# Dauer in Sekunden für jede Priorität
const DISPLAY_DURATION = {
	\"low\": 4.0,      # Tips, Info
	\"normal\": 6.0,   # Events, Patches
	\"high\": 8.0,     # Warnings
	\"critical\": 0.0  # Bleibt bis geklickt (0 = unendlich)
}

# ---------------------------------------------------
# 🎬 Lebenszyklus
# ---------------------------------------------------
func _ready() -> void:
	$BackgroundSprite/AnimationPlayer.play(\"loop\")
	load_settings()
	set_uuid_label()
	create_game_messages_ui()
	fetch_game_messages()

func set_uuid_label() -> void:
	var player_id = load_or_create_player_id()
	$UUID.text = \"UUID: \" + player_id

# ---------------------------------------------------
# 🆕 Game Messages Funktionen
# ---------------------------------------------------
func create_game_messages_ui() -> void:
	game_messages_container = VBoxContainer.new()
	game_messages_container.name = \"ToastsContainer\"

	game_messages_container.anchor_left = 1.0
	game_messages_container.anchor_top = 1.0
	game_messages_container.anchor_right = 1.0
	game_messages_container.anchor_bottom = 1.0
	game_messages_container.offset_right = -30
	game_messages_container.offset_bottom = -30
	game_messages_container.offset_left = -430
	game_messages_container.offset_top = -500

	game_messages_container.mouse_filter = Control.MOUSE_FILTER_IGNORE
	game_messages_container.alignment = BoxContainer.ALIGNMENT_END
	game_messages_container.grow_vertical = Control.GROW_DIRECTION_BEGIN
	game_messages_container.size_flags_vertical = Control.SIZE_SHRINK_END
	game_messages_container.custom_minimum_size = Vector2(400, 0)

	add_child(game_messages_container)

	message_timer = Timer.new()
	message_timer.name = \"MessageTimer\"
	message_timer.wait_time = 300.0
	message_timer.autostart = true
	message_timer.timeout.connect(fetch_game_messages)
	add_child(message_timer)

	print(\"✅ Toast UI unten rechts erstellt\")

# ---------------------------------------------------
# 🔁 Game Messages abrufen
# ---------------------------------------------------
func fetch_game_messages() -> void:
	# Cache für Offline-Betrieb prüfen
	if not Time.get_ticks_msec() - get_last_fetch_time() < 300000:  # 5 Minuten
		load_cached_messages()
		return
	
	if not toast_settings.enabled:
		return

	var http_request = HTTPRequest.new()
	add_child(http_request)
	http_request.request_completed.connect(_on_game_messages_request_completed.bind(http_request))

	var url = \"https://api.joeysslimeventure.com/api/game-messages\"
	var error = http_request.request(url)
	if error != OK:
		push_error(\"Fehler beim Abrufen der Game Messages: \" + str(error))
		load_cached_messages()
	else:
		print(\"🔄 Game Messages werden abgerufen von: \" + url)
	
	# Timeout hinzufügen
	await get_tree().create_timer(10.0).timeout
	if is_instance_valid(http_request):
		http_request.queue_free()
		load_cached_messages()

func _on_game_messages_request_completed(result: int, response_code: int, headers: PackedStringArray, body: PackedByteArray, http_request: HTTPRequest) -> void:
	http_request.queue_free()
	
	if result != HTTPRequest.RESULT_SUCCESS:
		push_error(\"HTTP Request fehlgeschlagen: \" + str(result))
		load_cached_messages()
		return
	
	if response_code != 200:
		push_error(\"Server Fehler: \" + str(response_code))
		load_cached_messages()
		return

	var json = JSON.new()
	var parse_result = json.parse(body.get_string_from_utf8())
	if parse_result != OK:
		push_error(\"JSON Parse Fehler: \" + str(parse_result))
		load_cached_messages()
		return

	var response = json.get_data()
	if response and response.has(\"messages\"):
		# Nachrichten im Cache speichern
		save_messages_to_cache(response[\"messages\"])
		display_game_messages(response[\"messages\"])
	else:
		print(\"❌ Keine Nachrichten erhalten oder ungültige Antwort\")
		load_cached_messages()

# ---------------------------------------------------
# 📢 Mehrere Toast-Nachrichten gleichzeitig
# ---------------------------------------------------
func display_game_messages(messages: Array) -> void:
	if not toast_settings.enabled:
		return
	
	# Nachrichten gruppieren
	var grouped_messages = group_similar_messages(messages)
	
	# Nach Priorität UND Zeitstempel sortieren
	grouped_messages.sort_custom(func(a, b): 
		var priority_a = get_priority_value(a.get(\"priority\", \"normal\"))
		var priority_b = get_priority_value(b.get(\"priority\", \"normal\"))
		if priority_a != priority_b:
			return priority_a > priority_b
		# Bei gleicher Priorität: Ältere zuerst
		return a.get(\"timestamp\", 0) < b.get(\"timestamp\", 0)
	)
	
	# Verzögerung zwischen Toasts für bessere Lesbarkeit
	for i in range(grouped_messages.size()):
		await get_tree().create_timer(i * 0.3).timeout
		show_toast(grouped_messages[i])

func show_toast(message: Dictionary) -> void:
	if not toast_settings.enabled:
		return
	
	# Alte Toasts entfernen wenn Limit erreicht
	if active_toasts.size() >= toast_settings.max_count:
		var oldest_toast = active_toasts.pop_front()
		if is_instance_valid(oldest_toast):
			animate_toast_removal(oldest_toast)
	
	var toast = create_toast(message)
	game_messages_container.add_child(toast)
	active_toasts.append(toast)
	toast_stats.shown += 1

	# Animation einblenden
	toast.modulate = Color(1, 1, 1, 0)
	toast.scale = Vector2(0.9, 0.9)
	var tween = create_tween()
	tween.set_parallel(true)
	tween.tween_property(toast, \"modulate:a\", 1.0, 0.3).set_trans(Tween.TRANS_SINE).set_ease(Tween.EASE_OUT)
	tween.tween_property(toast, \"scale\", Vector2(1, 1), 0.4).set_trans(Tween.TRANS_BACK).set_ease(Tween.EASE_OUT)
	tween.set_parallel(false)

	# Dauer basierend auf Priorität und Einstellungen
	var priority = message.get(\"priority\", \"normal\")
	var duration = DISPLAY_DURATION.get(priority, 6.0) * toast_settings.duration_multiplier
	
	if duration > 0:  # Automatisch ausblenden
		tween.tween_interval(duration)
		tween.tween_property(toast, \"modulate:a\", 0.0, 0.5).set_trans(Tween.TRANS_SINE).set_ease(Tween.EASE_IN)
		tween.parallel().tween_property(toast, \"scale\", Vector2(0.95, 0.95), 0.5).set_trans(Tween.TRANS_SINE).set_ease(Tween.EASE_IN)
		tween.tween_callback(func():
			if is_instance_valid(toast):
				active_toasts.erase(toast)
				toast_stats.dismissed += 1
				recycle_toast_to_pool(toast)
		)
	# critical (duration = 0) bleibt bis geklickt

# ---------------------------------------------------
# 💬 Toast erstellen (mit Close-Button & Pooling)
# ---------------------------------------------------
func create_toast(message: Dictionary) -> PanelContainer:
	var toast: PanelContainer
	if toast_pool.is_empty():
		toast = create_new_toast(message)
	else:
		toast = toast_pool.pop_back()
		recycle_toast_with_message(toast, message)
		toast.show()
	
	return toast

func create_new_toast(message: Dictionary) -> PanelContainer:
	var toast = PanelContainer.new()
	toast.mouse_filter = Control.MOUSE_FILTER_STOP
	toast.custom_minimum_size = Vector2(420, 0)
	
	var message_type = message.get(\"type\", \"info\")
	var priority = message.get(\"priority\", \"normal\")

	var style = StyleBoxFlat.new()
	style.set_border_width_all(2)
	style.border_color = get_message_border_color(message_type)
	style.bg_color = get_message_color(message_type)
	style.corner_radius_top_left = 12
	style.corner_radius_top_right = 12
	style.corner_radius_bottom_left = 12
	style.corner_radius_bottom_right = 12
	style.shadow_size = 6
	style.shadow_color = Color(0, 0, 0, 0.4)
	toast.add_theme_stylebox_override(\"panel\", style)

	# Haupt-Container
	var hbox = HBoxContainer.new()
	hbox.add_theme_constant_override(\"separation\", 8)
	hbox.size_flags_horizontal = Control.SIZE_EXPAND_FILL

	var vbox = VBoxContainer.new()
	vbox.add_theme_constant_override(\"separation\", 4)
	vbox.size_flags_horizontal = Control.SIZE_EXPAND_FILL

	# Titelzeile mit Icon und Close-Button
	var title_hbox = HBoxContainer.new()
	title_hbox.size_flags_horizontal = Control.SIZE_EXPAND_FILL

	var title_label = Label.new()
	var custom_title = message.get(\"title\", \"\")
	
	if custom_title != \"\":
		title_label.text = get_message_icon(message_type) + \" \" + custom_title
	else:
		title_label.text = get_message_icon(message_type) + \" \" + get_default_title(message_type)
	
	title_label.add_theme_font_size_override(\"font_size\", 16)
	title_label.add_theme_color_override(\"font_color\", Color.WHITE)
	title_label.size_flags_horizontal = Control.SIZE_EXPAND_FILL

	# Close-Button für alle Toasts
	var close_button = Button.new()
	close_button.text = \"×\"
	close_button.add_theme_font_size_override(\"font_size\", 18)
	close_button.add_theme_color_override(\"font_color\", Color.WHITE)
	close_button.flat = true
	close_button.custom_minimum_size = Vector2(24, 24)
	close_button.pressed.connect(func(): 
		if is_instance_valid(toast):
			toast_stats.dismissed += 1
			animate_toast_removal(toast)
	)

	title_hbox.add_child(title_label)
	title_hbox.add_child(close_button)

	# Nachrichtentext
	var text_label = Label.new()
	text_label.text = message.get(\"text\", \"\")
	text_label.autowrap_mode = TextServer.AUTOWRAP_WORD
	text_label.add_theme_font_size_override(\"font_size\", 13)
	text_label.add_theme_color_override(\"font_color\", Color(1, 1, 1, 0.9))

	# Prioritäts-Badge bei critical/high
	if priority in [\"critical\", \"high\"]:
		var priority_badge = Label.new()
		priority_badge.text = get_priority_badge(priority)
		priority_badge.add_theme_font_size_override(\"font_size\", 11)
		priority_badge.add_theme_color_override(\"font_color\", get_priority_color(priority))
		vbox.add_child(priority_badge)

	vbox.add_child(title_hbox)
	vbox.add_child(text_label)
	hbox.add_child(vbox)
	toast.add_child(hbox)

	# Hover-Effekte
	toast.mouse_entered.connect(func(): 
		if toast.has_meta(\"tween\") and toast.get_meta(\"tween\"):
			toast.get_meta(\"tween\").pause()
		var hover_tween = create_tween()
		hover_tween.tween_property(toast, \"scale\", Vector2(1.02, 1.02), 0.1)
	)
	
	toast.mouse_exited.connect(func(): 
		if toast.has_meta(\"tween\") and toast.get_meta(\"tween\"):
			toast.get_meta(\"tween\").play()
		var hover_tween = create_tween()
		hover_tween.tween_property(toast, \"scale\", Vector2(1, 1), 0.1)
	)

	# Klick-Handler für gesamten Toast
	toast.gui_input.connect(func(event):
		if event is InputEventMouseButton and event.pressed:
			if event.button_index == MOUSE_BUTTON_LEFT:
				toast_stats.clicked += 1
				on_toast_clicked(message, toast)
	)

	return toast

func recycle_toast_with_message(toast: PanelContainer, message: Dictionary) -> void:
	# Toast-Inhalt aktualisieren
	var vbox = toast.get_child(0).get_child(0) as VBoxContainer
	var title_hbox = vbox.get_child(0) as HBoxContainer
	var title_label = title_hbox.get_child(0) as Label
	var text_label = vbox.get_child(1) as Label
	
	var message_type = message.get(\"type\", \"info\")
	var priority = message.get(\"priority\", \"normal\")
	var custom_title = message.get(\"title\", \"\")
	
	if custom_title != \"\":
		title_label.text = get_message_icon(message_type) + \" \" + custom_title
	else:
		title_label.text = get_message_icon(message_type) + \" \" + get_default_title(message_type)
	
	text_label.text = message.get(\"text\", \"\")
	
	# Style aktualisieren
	var style = StyleBoxFlat.new()
	style.set_border_width_all(2)
	style.border_color = get_message_border_color(message_type)
	style.bg_color = get_message_color(message_type)
	style.corner_radius_top_left = 12
	style.corner_radius_top_right = 12
	style.corner_radius_bottom_left = 12
	style.corner_radius_bottom_right = 12
	style.shadow_size = 6
	style.shadow_color = Color(0, 0, 0, 0.4)
	toast.add_theme_stylebox_override(\"panel\", style)

func recycle_toast_to_pool(toast: PanelContainer) -> void:
	toast_pool.append(toast)
	toast.hide()
	if toast.get_parent():
		toast.get_parent().remove_child(toast)

func animate_toast_removal(toast: PanelContainer) -> void:
	var tween = create_tween()
	tween.set_parallel(true)
	tween.tween_property(toast, \"modulate:a\", 0.0, 0.3).set_trans(Tween.TRANS_SINE).set_ease(Tween.EASE_IN)
	tween.tween_property(toast, \"scale\", Vector2(0.95, 0.95), 0.3).set_trans(Tween.TRANS_SINE).set_ease(Tween.EASE_IN)
	tween.set_parallel(false)
	tween.tween_callback(func():
		if is_instance_valid(toast):
			active_toasts.erase(toast)
			recycle_toast_to_pool(toast)
	)

# ---------------------------------------------------
# 🎯 Toast-Interaktionen
# ---------------------------------------------------
func on_toast_clicked(message: Dictionary, toast: PanelContainer) -> void:
	# Spezielle Aktionen basierend auf Nachrichtentyp
	match message.get(\"action_type\", \"\"):
		\"open_url\":
			if message.has(\"action_data\"):
				OS.shell_open(message[\"action_data\"])
		\"open_settings\":
			_on_settings_button_pressed()
		\"copy_text\":
			if message.has(\"text\"):
				DisplayServer.clipboard_set(message[\"text\"])
		\"dismiss_all\":
			dismiss_all_toasts()
	
	# Toast schließen nach Klick (auch bei critical)
	animate_toast_removal(toast)

func dismiss_all_toasts() -> void:
	for toast in active_toasts.duplicate():
		if is_instance_valid(toast):
			animate_toast_removal(toast)

# ---------------------------------------------------
# 🔄 Cache & Offline-Funktionalität
# ---------------------------------------------------
func get_last_fetch_time() -> int:
	return config.get_value(\"toasts\", \"last_fetch\", 0)

func set_last_fetch_time() -> void:
	config.set_value(\"toasts\", \"last_fetch\", Time.get_ticks_msec())
	config.save(CONFIG_PATH)

func save_messages_to_cache(messages: Array) -> void:
	var file = FileAccess.open(\"user://cached_messages.json\", FileAccess.WRITE)
	if file:
		var data = {
			\"messages\": messages,
			\"timestamp\": Time.get_ticks_msec()
		}
		file.store_string(JSON.stringify(data))
		file.close()
	set_last_fetch_time()

func load_cached_messages() -> void:
	var file = FileAccess.open(\"user://cached_messages.json\", FileAccess.READ)
	if file:
		var json = JSON.new()
		var parse_result = json.parse(file.get_as_text())
		if parse_result == OK:
			var data = json.get_data()
			if data and data.has(\"messages\"):
				print(\"📂 Geladene Nachrichten aus Cache\")
				display_game_messages(data[\"messages\"])
				return
	print(\"❌ Keine gecachten Nachrichten gefunden\")

# ---------------------------------------------------
# 🎨 Farben, Icons, Titel & Prioritäten
# ---------------------------------------------------
func get_message_icon(message_type: String) -> String:
	match message_type:
		\"info\": return \"💡\"
		\"tip\": return \"✨\"
		\"event\": return \"🎉\"
		\"patch\": return \"🔧\"
		\"warning\": return \"⚠️\"
		\"love\": return \"❤️\"
		_: return \"📢\"

func get_default_title(message_type: String) -> String:
	match message_type:
		\"info\": return \"Information\"
		\"tip\": return \"Tipp des Tages\"
		\"event\": return \"Aktuelles Event\"
		\"patch\": return \"Patch Notes\"
		\"warning\": return \"Wichtiger Hinweis\"
		\"love\": return \"Von den Entwicklern\"
		_: return \"Nachricht\"

func get_priority_value(priority: String) -> int:
	match priority:
		\"critical\": return 4
		\"high\": return 3
		\"normal\": return 2
		\"low\": return 1
		_: return 2

func get_priority_badge(priority: String) -> String:
	match priority:
		\"critical\": return \"🚨 DRINGEND\"
		\"high\": return \"⚠️ WICHTIG\"
		_: return \"\"

func get_priority_color(priority: String) -> Color:
	match priority:
		\"critical\": return Color(1.0, 0.3, 0.3)
		\"high\": return Color(1.0, 0.8, 0.3)
		_: return Color.WHITE

func get_message_color(message_type: String) -> Color:
	match message_type:
		\"info\": return Color(0.1, 0.2, 0.4, 0.9)
		\"tip\": return Color(0.0, 0.3, 0.2, 0.9)
		\"event\": return Color(0.3, 0.2, 0.0, 0.9)
		\"patch\": return Color(0.3, 0.0, 0.3, 0.9)
		\"warning\": return Color(0.4, 0.0, 0.0, 0.9)
		\"love\": return Color(0.5, 0.1, 0.3, 0.9)
		_: return Color(0.1, 0.2, 0.4, 0.9)

func get_message_border_color(message_type: String) -> Color:
	match message_type:
		\"info\": return Color(0.2, 0.8, 1.0)
		\"tip\": return Color(0.2, 1.0, 0.6)
		\"event\": return Color(1.0, 0.8, 0.0)
		\"patch\": return Color(0.8, 0.4, 1.0)
		\"warning\": return Color(1.0, 0.2, 0.2)
		\"love\": return Color(1.0, 0.4, 0.8)
		_: return Color(0.2, 0.8, 1.0)

# ---------------------------------------------------
# 🎪 Toast-Gruppierung
# ---------------------------------------------------
func group_similar_messages(messages: Array) -> Array:
	var grouped = []
	var handled_ids = {}
	
	for message in messages:
		var message_id = message.get(\"id\", \"\")
		if message_id and message_id in handled_ids:
			continue
		
		if message_id:
			handled_ids[message_id] = true
		
		# Gruppiere ähnliche Nachrichten (gleicher Typ + ähnlicher Text)
		var similar_found = false
		for existing in grouped:
			if (existing.get(\"type\") == message.get(\"type\") and 
				existing.get(\"priority\") == message.get(\"priority\") and
				are_messages_similar(existing.get(\"text\", \"\"), message.get(\"text\", \"\"))):
				similar_found = true
				break
		
		if not similar_found:
			grouped.append(message)
	
	return grouped

func are_messages_similar(text1: String, text2: String) -> bool:
	# Einfache Ähnlichkeitsprüfung
	var words1 = text1.to_lower().split(\" \")
	var words2 = text2.to_lower().split(\" \")
	var common_words = 0
	
	for word in words1:
		if word in words2 and word.length() > 3:
			common_words += 1
	
	return common_words >= min(words1.size(), words2.size()) * 0.6

# ---------------------------------------------------
# ⚙️ Settings (erweitert um Toast-Einstellungen)
# ---------------------------------------------------
func load_settings() -> void:
	if config.load(CONFIG_PATH) != OK:
		return
	
	# Audio-Einstellungen
	var volume = config.get_value(\"audio\", \"volume\", 0.0)
	AudioServer.set_bus_volume_db(0, volume)
	if volume_slider:
		volume_slider.value = db_to_linear(volume)
	var mute = config.get_value(\"audio\", \"mute\", false)
	AudioServer.set_bus_mute(0, mute)
	
	# Graphics-Einstellungen
	var resolution_index = config.get_value(\"graphics\", \"resolution\", 2)
	set_resolution(resolution_index)
	
	# Toast-Einstellungen
	toast_settings.enabled = config.get_value(\"toasts\", \"enabled\", true)
	toast_settings.duration_multiplier = config.get_value(\"toasts\", \"duration_multiplier\", 1.0)
	toast_settings.max_count = config.get_value(\"toasts\", \"max_count\", 5)
	toast_settings.position = config.get_value(\"toasts\", \"position\", \"bottom_right\")

func set_resolution(index: int) -> void:
	var resolutions = [
		Vector2i(3840, 2160),
		Vector2i(2560, 1440),
		Vector2i(1920, 1080),
		Vector2i(1600, 900),
		Vector2i(1366, 768),
		Vector2i(1280, 720)
	]
	if index >= 0 and index < resolutions.size():
		DisplayServer.window_set_size(resolutions[index])

# ---------------------------------------------------
# 🔊 Lautstärke & Buttons (unverändert)
# ---------------------------------------------------
func _on_volume_slider_value_changed(value: float) -> void:
	var db_value = linear_to_db(value)
	AudioServer.set_bus_volume_db(0, db_value)
	config.set_value(\"audio\", \"volume\", db_value)
	config.save(CONFIG_PATH)

func _on_play_button_pressed() -> void:
	var level_scene_path = \"res://Scenes/Game.tscn\"
	var level_resource = load(\"user://current_level.res\")
	if level_resource and level_resource.has_method(\"get\"):
		level_scene_path = level_resource.unlocked_level
		if not ResourceLoader.exists(level_scene_path):
			print(\"⚠ Level ungültig, fallback auf Startlevel\")
			level_scene_path = \"res://Scenes/Game.tscn\"

	var transition = preload(\"res://Scenes/transition.tscn\").instantiate()
	get_tree().root.add_child(transition)
	transition.play_transition(level_scene_path, false)

func _on_settings_button_pressed() -> void:
	change_scene(\"res://Scenes/settings.tscn\")

func _on_credits_button_pressed() -> void:
	change_scene(\"res://Scenes/credits.tscn\")

func _on_quit_button_pressed() -> void:
	get_tree().quit()

func _on_matchmaking_pressed() -> void:
	var game_manager = get_node(\"/root/GameManager\")
	game_manager.join_dedicated_server()
	hide()

func change_scene(scene_path: String) -> void:
	var new_scene = load(scene_path)
	if new_scene == null:
		print(\"Fehler: Szene konnte nicht geladen werden.\")
		return
	var scene_instance = new_scene.instantiate()
	if get_tree().current_scene:
		get_tree().current_scene.queue_free()
	get_tree().root.add_child(scene_instance)
	get_tree().current_scene = scene_instance

# ---------------------------------------------------
# 🔒 Hash & ID-Funktionen (unverändert)
# ---------------------------------------------------
func get_signature(player_id: String) -> String:
	var ctx := HashingContext.new()
	ctx.start(HashingContext.HASH_SHA256)
	ctx.update(player_id.to_utf8_buffer() + SECRET_SALT.to_utf8_buffer())
	var hash: PackedByteArray = ctx.finish()
	return hash.hex_encode()

func save_player_id(player_id: String) -> void:
	var sig = get_signature(player_id)
	var file = FileAccess.open(PLAYER_ID_PATH, FileAccess.WRITE)
	if file:
		file.store_line(player_id)
		file.store_line(sig)
		file.close()

func load_or_create_player_id() -> String:
	if FileAccess.file_exists(PLAYER_ID_PATH):
		var file = FileAccess.open(PLAYER_ID_PATH, FileAccess.READ)
		if file:
			var player_id = file.get_line().strip_edges()
			var sig = file.get_line().strip_edges()
			file.close()
			if sig == get_signature(player_id):
				return player_id
			else:
				push_warning(\"⚠ Manipulierte Player-ID entdeckt → neue ID wird generiert.\")
	var new_id = OS.get_unique_id()
	save_player_id(new_id)
	return new_id
