[gd_scene load_steps=6 format=3 uid="uid://cky4br4n3cm1o"]

[sub_resource type="GDScript" id="GDScript_1j2a0"]
script/source = "extends Control

@export var duration := 3.0
@export var message_type := \"info\"

@onready var panel = $BackgroundPanel
@onready var label = $BackgroundPanel/MessageLabel
@onready var anim = $AnimationPlayer

func _ready():
	panel.modulate = get_color_for_type(message_type)
	label.add_theme_font_size_override(\"font_size\", 18)
	label.autowrap = true
	label.align = HORIZONTAL_ALIGNMENT_CENTER
	label.valign = VERTICAL_ALIGNMENT_CENTER
	panel.scale = Vector2(0.9, 0.9)
	anim.play(\"fade_in\")

	await get_tree().create_timer(duration).timeout
	anim.play(\"fade_out\")
	await anim.animation_finished
	queue_free()

func set_message(text: String, type := \"info\"):
	label.text = text
	message_type = type
	panel.modulate = get_color_for_type(type)

func get_color_for_type(type: String) -> Color:
	match type:
		\"success\":
			return Color(0.3, 0.9, 0.5, 0.85)
		\"warning\":
			return Color(0.95, 0.8, 0.3, 0.85)
		\"error\":
			return Color(0.95, 0.3, 0.3, 0.85)
		_:
			return Color(0.4, 0.6, 1.0, 0.85)
"

