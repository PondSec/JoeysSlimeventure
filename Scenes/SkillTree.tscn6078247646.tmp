script/source = "extends CanvasLayer

func _ready():
	self.visible = false

func _process(delta: float) -> void:
	if Input.is_action_just_pressed(\"skill_tree\"):
		self.visible = !self.visible
"

[sub_resource type="GDScript" id="GDScript_d8ypo"]
script/source = "extends Control

class_name SkillTree

# Texturen für die Nodes
var node_texture = preload(\"res://Assets/SkillTree/SkillNodeActive.png\")
var node_active_texture = preload(\"res://Assets/SkillTree/SkillNodeActive.png\")
var node_hover_texture = preload(\"res://Assets/SkillTree/SkillNodeHover.png\")

# Referenz zum Player-Skript
var player: Node

# Skill-Definitionen: [Name, Position, Voraussetzungen, Level-Anforderung, Beschreibung]
var skills = {
	\"wall_slide\": {
		\"pos\": Vector2(200, 200), 
		\"unlocked\": false, 
		\"requires\": [], 
		\"required_levels\": [\"level1\"],
		\"description\": \"Erlaubt das Herunterrutschen an Wänden\"
	},
	\"ult\": {
		\"pos\": Vector2(400, 200), 
		\"unlocked\": false, 
		\"requires\": [\"wall_slide\"], 
		\"required_levels\": [\"level2\"],
		\"description\": \"Spezialfähigkeit mit großer Wirkung\"
	}
}

var connections = [
	[\"wall_slide\", \"ult\"]
]

var hovered_node = null
var skill_tooltip_visible := false
var skill_tooltip_text := \"\"

# Signal, das ausgelöst wird, wenn ein Skill freigeschaltet wird
signal skill_unlocked(skill_name)

func _ready():
	# Player-Referenz holen
	player = get_tree().get_first_node_in_group(\"players\")
	if not player:
		push_error(\"Player-Node nicht gefunden!\")
	
	# Tooltip-Label erstellen
	create_tooltip()
	
	# Verbinde das Level-Completed-Signal von allen Türen
	connect_to_doors()
	
	load_skills()
	update_skill_tree()

func connect_to_doors():
	# Finde alle Türen in der Szene und verbinde ihre Signale
	var doors = get_tree().get_nodes_in_group(\"doors\")
	for door in doors:
		if door.has_signal(\"level_completed\"):
			door.level_completed.connect(_on_level_completed)

func _on_level_completed(level_name: String):
	print(\"Level abgeschlossen: \", level_name, \" - Aktualisiere Skillbaum\")
	queue_redraw()  # Skillbaum neu zeichnen

func _draw():
	# Verbindungen zeichnen
	for connection in connections:
		var from_node = skills[connection[0]]
		var to_node = skills[connection[1]]
		
		var line_color
		if from_node.unlocked and to_node.unlocked:
			line_color = Color.WHITE
		elif can_unlock_skill(connection[0]) and can_unlock_skill(connection[1]):
			line_color = Color.LIGHT_GRAY
		else:
			line_color = Color.DARK_GRAY
		
		draw_line(from_node.pos, to_node.pos, line_color, 2)
	
	# Nodes zeichnen
	for skill_name in skills:
		var skill = skills[skill_name]
		var texture
		var node_color = Color.WHITE
		
		# Bestimme die Textur und Farbe basierend auf Status
		if skill.unlocked:
			texture = node_active_texture
		elif can_unlock_skill(skill_name):
			texture = node_texture  # Kann freigeschaltet werden
		else:
			texture = node_texture
			node_color = Color(0.5, 0.5, 0.5, 0.6)  # Ausgegraut
		
		if hovered_node == skill_name:
			texture = node_hover_texture
			node_color = Color.WHITE
		
		# Zeichne die Textur mit der entsprechenden Farbe
		draw_set_transform(skill.pos - texture.get_size() / 2, 0, Vector2.ONE)
		draw_texture(texture, Vector2.ZERO, node_color)
		draw_set_transform_matrix(Transform2D.IDENTITY)
		
		# Zeige benötigte Level
		var font = ThemeDB.fallback_font
		var font_size = 10
		var levels_text = \"Lvls: \" + \", \".join(skill.required_levels)
		var text_pos = Vector2(0, texture.get_size().y / 2 + 5)  # Relative Position
		
		# Textfarbe basierend auf Verfügbarkeit
		var text_color = node_color
		if not can_unlock_skill(skill_name) and not skill.unlocked:
			text_color = Color.GRAY
		
		draw_string(font, skill.pos + text_pos, levels_text, HORIZONTAL_ALIGNMENT_CENTER, -1, font_size, text_color)

func _input(event):
	if event is InputEventMouseMotion:
		var mouse_pos = get_local_mouse_position()
		hovered_node = null
		skill_tooltip_visible = false
		
		for skill_name in skills:
			var skill = skills[skill_name]
			var texture = node_active_texture if skill.unlocked else node_texture
			var rect = Rect2(skill.pos - texture.get_size() / 2, texture.get_size())
			
			if rect.has_point(mouse_pos):
				hovered_node = skill_name
				skill_tooltip_visible = true
				
				# Erstelle Tooltip-Text mit benötigten Leveln
				var levels_text = \"Benötigte Level: \" + \", \".join(skill.required_levels)
				skill_tooltip_text = skill.description + \"\\n\" + levels_text
				
				# Füge Info über fehlende Level hinzu
				var completed_levels = load_completed_levels()
				var missing_levels = []
				for req_level in skill.required_levels:
					if not req_level in completed_levels:
						missing_levels.append(req_level)
				
				if missing_levels.size() > 0:
					skill_tooltip_text += \"\\n\\nFehlende Level: \" + \", \".join(missing_levels)
				
				break
		
		queue_redraw()
	
	if event is InputEventMouseButton and event.pressed:
		if hovered_node and skills[hovered_node].unlocked == false:
			# Prüfe Voraussetzungen
			var can_unlock = true
			for req in skills[hovered_node].requires:
				if not skills[req].unlocked:
					can_unlock = false
					break
			
			# Prüfe Level-Anforderung
			if can_unlock and player and player.player_level >= skills[hovered_node].level_required:
				skills[hovered_node].unlocked = true
				skill_unlocked.emit(hovered_node)
				save_skills()
				queue_redraw()

func queue_update():
	queue_redraw()

func update_skill_tree():
	queue_redraw()

func can_unlock_skill(skill_name: String) -> bool:
	var skill_data = skills.get(skill_name)
	if not skill_data:
		print(\"Skill nicht gefunden: \", skill_name)
		return false
	
	# Überprüfe, ob alle benötigten Level abgeschlossen wurden
	var completed_levels = load_completed_levels()
	print(\"Abgeschlossene Level: \", completed_levels)
	print(\"Benötigte Level für \", skill_name, \": \", skill_data.required_levels)
	
	for required_level in skill_data.required_levels:
		if not required_level in completed_levels:
			print(\"Fehlendes Level: \", required_level)
			return false
	
	# Überprüfe Skill-Voraussetzungen
	for req in skill_data.requires:
		if not skills[req].unlocked:
			print(\"Fehlender vorheriger Skill: \", req)
			return false
	
	print(\"Skill kann freigeschaltet werden: \", skill_name)
	return true

func create_tooltip():
	# Tooltip-Label erstellen
	var tooltip = Label.new()
	tooltip.name = \"Tooltip\"
	tooltip.visible = false
	tooltip.z_index = 100
	tooltip.add_theme_color_override(\"font_color\", Color.WHITE)
	tooltip.add_theme_font_size_override(\"font_size\", 12)
	tooltip.add_theme_stylebox_override(\"normal\", create_tooltip_stylebox())
	tooltip.autowrap_mode = TextServer.AUTOWRAP_WORD_SMART
	tooltip.custom_minimum_size = Vector2(150, 60)
	add_child(tooltip)

func create_tooltip_stylebox() -> StyleBoxFlat:
	var stylebox = StyleBoxFlat.new()
	stylebox.bg_color = Color(0.1, 0.1, 0.1, 0.9)
	stylebox.border_color = Color(0.5, 0.5, 0.5)
	stylebox.border_width_left = 2
	stylebox.border_width_right = 2
	stylebox.border_width_top = 2
	stylebox.border_width_bottom = 2
	stylebox.corner_radius_top_left = 5
	stylebox.corner_radius_top_right = 5
	stylebox.corner_radius_bottom_right = 5
	stylebox.corner_radius_bottom_left = 5
	stylebox.content_margin_left = 8
	stylebox.content_margin_right = 8
	stylebox.content_margin_top = 8
	stylebox.content_margin_bottom = 8
	return stylebox

func _process(_delta):
	# Tooltip-Position aktualisieren
	if skill_tooltip_visible and hovered_node:
		var tooltip = $Tooltip
		if tooltip:
			tooltip.text = skill_tooltip_text
			tooltip.visible = true
			tooltip.position = get_global_mouse_position() + Vector2(20, 20)
	else:
		var tooltip = $Tooltip
		if tooltip:
			tooltip.visible = false

# Speichern und Laden
func save_skills():
	var save_data = {}
	for skill_name in skills:
		save_data[skill_name] = {
			\"unlocked\": skills[skill_name].unlocked,
			\"level_required\": skills[skill_name].level_required
		}
	
	var save_game = FileAccess.open(\"user://skills.save\", FileAccess.WRITE)
	if save_game:
		save_game.store_string(JSON.stringify(save_data))
		save_game.close()

func load_skills():
	if FileAccess.file_exists(\"user://skills.save\"):
		var save_game = FileAccess.open(\"user://skills.save\", FileAccess.READ)
		if save_game:
			var json_data = save_game.get_as_text()
			save_game.close()
			
			var save_data = JSON.parse_string(json_data)
			if save_data:
				for skill_name in save_data:
					if skills.has(skill_name):
						skills[skill_name].unlocked = save_data[skill_name].unlocked
						
						# Aktiviere die Skills im Player-Skript
						if save_data[skill_name].unlocked and player:
							match skill_name:
								\"wall_slide\":
									player.has_wall_slide_skill = true
								\"ult\":
									player.has_ult_skill = true
	
	queue_redraw()

# Funktion zum manuellen Freischalten eines Skills (für Debugging)
func unlock_skill(skill_name: String):
	if skills.has(skill_name):
		skills[skill_name].unlocked = true
		skill_unlocked.emit(skill_name)
		save_skills()
		queue_redraw()

# Funktion zum Zurücksetzen aller Skills
func reset_skills():
	for skill_name in skills:
		skills[skill_name].unlocked = false
	
	if FileAccess.file_exists(\"user://skills.save\"):
		DirAccess.remove_absolute(\"user://skills.save\")
	
	queue_redraw()

func load_completed_levels() -> Array:
	if FileAccess.file_exists(\"user://completed_levels.save\"):
		var file = FileAccess.open(\"user://completed_levels.save\", FileAccess.READ)
		var data = JSON.parse_string(file.get_as_text())
		file.close()
		if data is Array:
			return data
	return []
"

