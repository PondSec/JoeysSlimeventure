[sub_resource type="GDScript" id="GDScript_cywlo"]
script/source = "# ParallaxController.gd
extends ParallaxBackground

@export var scroll_speed_base: float = 50.0

func _ready():
	# Stelle sicher, dass alle Layer korrekt eingestellt sind
	for layer in get_children():
		if layer is ParallaxLayer:
			# Motion Mirroring für nahtlose Wiederholung
			layer.motion_mirroring = Vector2(
				layer.get_child(0).texture.get_width(),
				layer.get_child(0).texture.get_height()
			)

func _process(delta):
	# Automatisches Scrollen im Hintergrund
	scroll_offset.x += scroll_speed_base * delta
	
	# Optional: Mit Spieler-Kamera verbinden
	# scroll_offset = -get_viewport().get_camera_2d().global_position
"

