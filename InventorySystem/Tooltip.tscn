[sub_resource type="GDScript" id="GDScript_v2krb"]
script/source = "extends Control

@onready var panel = $Panel
@onready var item_name_label = $Panel/MarginContainer/VBoxContainer/ItemName
@onready var separator = $Panel/MarginContainer/VBoxContainer/HSeparator
@onready var stats_label = $Panel/MarginContainer/VBoxContainer/StatsLabel

func _ready():
	# Initial verstecken
	visible = false
	# Stelle sicher, dass der Tooltip über anderen UI-Elementen liegt
	z_index = 100

func show_tooltip(item: InvItem, position: Vector2):
	if item:
		# Item-Namen mit stylischem Format anzeigen
		item_name_label.text = item.name
		
		# Bestimme die Farbe basierend auf der Item-Stärke
		var name_color = determine_rarity_color(item)
		item_name_label.modulate = name_color
		
		# Stats-Text mit BBCode für cooles Formatting
		var stats_text = \"\"
		
		# Drop Chance anzeigen (immer, falls vorhanden)
		if item.drop_chance > 0:
			var drop_chance_percent = item.drop_chance * 100
			stats_text += \"[img=16]res://InventorySystem/Icons/drop_chance_icon.png[/img] [color=#4ECB71]\" + str(drop_chance_percent) + \"%[/color] Drop Chance\\n\"

		# Ausrüstungsslot anzeigen
		if item.is_equipment and item.equip_slot != \"\":
			stats_text += \"[color=#FFD166]Ausrüstung: \" + item.equip_slot.capitalize() + \"[/color]\\n\"
		
		# Gesundheit
		if item.health_bonus != 0:
			var value = item.health_bonus * 100
			var sign = \"+\" if value > 0 else \"\"
			var color = \"#4ECB71\" if value > 0 else \"#CB4E4E\"
			stats_text += \"[img=16]res://InventorySystem/Icons/heart_icon.png[/img] [color=\" + color + \"]\" + sign + str(value) + \"%[/color] Gesundheit\\n\"
		
		# Schaden
		if item.damage_bonus != 0:
			var value = item.damage_bonus * 100
			var sign = \"+\" if value > 0 else \"\"
			var color = \"#4ECB71\" if value > 0 else \"#CB4E4E\"
			stats_text += \"[img=16]res://InventorySystem/Icons/sword_icon.png[/img] [color=\" + color + \"]\" + sign + str(value) + \"%[/color] Schaden\\n\"
		
		# Wurfschaden
		if item.throw_damage != 0:
			var value = item.throw_damage
			var sign = \"+\" if value > 0 else \"\"
			var color = \"#4ECB71\" if value > 0 else \"#CB4E4E\"
			stats_text += \"[img=16]res://InventorySystem/Icons/throw_icon.png[/img] [color=\" + color + \"]\" + sign + str(value) + \"[/color] Wurfschaden\\n\"
		
		# Crit-Chance
		if item.crit_chance_bonus != 0:
			var value = item.crit_chance_bonus * 100
			var sign = \"+\" if value > 0 else \"\"
			var color = \"#4ECB71\" if value > 0 else \"#CB4E4E\"
			stats_text += \"[img=16]res://InventorySystem/Icons/crit_icon.png[/img] [color=\" + color + \"]\" + sign + str(value) + \"%[/color] Crit-Chance\\n\"
		
		# Crit-Schaden
		if item.crit_damage_bonus != 0:
			var value = item.crit_damage_bonus * 100
			var sign = \"+\" if value > 0 else \"\"
			var color = \"#4ECB71\" if value > 0 else \"#CB4E4E\"
			stats_text += \"[img=16]res://InventorySystem/Icons/crit_damage_icon.png[/img] [color=\" + color + \"]\" + sign + str(value) + \"%[/color] Crit-Schaden\\n\"
			
		# Wenn keine Stats vorhanden sind
		if stats_text == \"\":
			stats_text = \"[color=#AAAAAA]Keine besonderen Eigenschaften[/color]\"
		
		stats_label.text = stats_text
		stats_label.bbcode_enabled = true
		
		# Trennlinie nur anzeigen wenn Stats vorhanden sind
		separator.visible = stats_text != \"[color=#AAAAAA]Keine besonderen Eigenschaften[/color]\"
		
		# Warte einen Frame damit die Größe berechnet werden kann
		await get_tree().process_frame
		
		# Positionieren
		global_position = position + Vector2(20, 20)
		
		# Begrenze die Position auf den Bildschirm
		var viewport_size = get_viewport().get_visible_rect().size
		var tooltip_size = size
		
		if global_position.x + tooltip_size.x > viewport_size.x:
			global_position.x = viewport_size.x - tooltip_size.x - 10
		if global_position.y + tooltip_size.y > viewport_size.y:
			global_position.y = viewport_size.y - tooltip_size.y - 10
		if global_position.x < 10:
			global_position.x = 10
		if global_position.y < 10:
			global_position.y = 10
		
		# Sichtbar machen
		visible = true

func determine_rarity_color(item: InvItem) -> Color:
	# Basis-Seltenheitswert basierend auf den Stats
	var weighted_throw_damage = abs(item.throw_damage) / 90.0
	var stats_value = (abs(item.health_bonus) + abs(item.damage_bonus) + 
					  weighted_throw_damage + abs(item.crit_chance_bonus) + 
					  abs(item.crit_damage_bonus))
	
	# Drop-Chance als Hauptfaktor für Seltenheit - je niedriger die Chance, desto seltener
	var drop_chance_value = 0.0
	if item.drop_chance > 0:
		# Umrechnung: 1% Drop-Chance = 0.5 Wert, 0.1% = 5.0 Wert
		drop_chance_value = (1.0 / item.drop_chance) * 0.08
	
	# Kombiniere beide Werte (Stats und Drop-Chance)
	var total_value = stats_value + drop_chance_value
	
	# DEBUG-Ausgabe zur Kontrolle
	print(\"Item: \", item.name)
	print(\"Stats-Wert: \", stats_value)
	print(\"Drop-Chance-Wert (1/drop_chance * 0.5): \", drop_chance_value)
	print(\"Gesamtwert: \", total_value)
	
	# Seltenheits-Schwellenwerte anpassen
	if total_value > 5.0:
		print(\"Seltenheit: Legendär (Orange)\")
		return Color(\"#FF6B00\")
	elif total_value > 2.0:
		print(\"Seltenheit: Episch (Lila)\")
		return Color(\"#9D4EDD\")
	elif total_value > 0.5:
		print(\"Seltenheit: Selten (Blau)\")
		return Color(\"#4CC9F0\")
	elif total_value > 0.1:
		print(\"Seltenheit: Ungewöhnlich (Grün)\")
		return Color(\"#4ECB71\")
	else:
		print(\"Seltenheit: Normal (Weiß)\")
		return Color(\"#FFFFFF\")

func hide_tooltip():
	visible = false
"

